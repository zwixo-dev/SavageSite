<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Bungee&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.globe.min.js"></script>
    <title>SavageSite</title>
    <style>
        *{
            padding: 0;
            margin: 0;
            box-sizing: border-box;
        }
        body{
            width: 100%;
            height: 100vh;
            overflow-x: hidden;
        }
        html::selection{
            background-color: transparent;
        }
        .home{
            border: 1px solid black;
            width: 100%;
            height: 100%;
            position: relative;
        }
        .home .module{
            width: 100%;
            height: 100%;
            z-index: -1;
        }
        .home .text{
            position: absolute;
            z-index: 1;
            top: 0;
            left: 10%;
            top: 39%;
            color: white;
            padding: 10px;
        }
        .home .text h1{
            font-family: 'Bungee', cursive;
            font-size: 2.4rem;
            letter-spacing: 1.01px;
            padding: 10px;
 
            /* Stylish upgrades */
            background: linear-gradient(135deg, #ffffff 0%, #ff8ab3 60%, #ff3f81 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: none;
            filter: drop-shadow(0 0 18px rgba(255,63,129,0.45));
        }
        .home .text p{
            font-family: 'Inter', sans-serif;
            font-size: 1.6rem;
            padding: 10px;
            color: rgba(255, 180, 210, 0.82);
            letter-spacing: 0.02em;
            font-weight: 400;
        }
        .home .text button{
            font-family: 'Inter', sans-serif;
            display: block;
            width: max-content;
            padding: 10px 20px;
            margin: 1rem;
            background: linear-gradient(135deg, #cc1f5f, #ff3f81);
            color: #fff;
            border: none;
            border-radius: 2px;
            font-weight: 600;
            font-size: 0.95rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            box-shadow: 0 0 20px rgba(255,63,129,0.4), 0 4px 15px rgba(0,0,0,0.3);
            transition: box-shadow 0.25s ease, transform 0.2s ease;
        }
 
        .home .text button::after {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
            transition: left 0.4s ease;
        }
 
        .home .text button:hover {
            box-shadow: 0 0 30px rgba(255,63,129,0.65), 0 6px 20px rgba(0,0,0,0.4);
            transform: translateY(-1px);
        }
    </style>
</head>
<body>
    <div class="home">
        <div class="module"></div>
        <form action="/analyze" method="GET">
            <div class="text">
                <h1>Welcome To SavageSite</h1>
                <p>Discover every design disaster hiding in your site</p>
                <button type="submit">Get Started</button>
            </div>
        </form>
    </div>

    <script>
        VANTA.GLOBE({
        el: ".module",
        mouseControls: true,
        touchControls: true,
        gyroControls: false,
        minHeight: 200.00,
        minWidth: 200.00,
        scale: 1.00,
        scaleMobile: 1.00,
        size: 1.40,
        backgroundColor: 0x100a18
        })
    </script>

</body>
</html>